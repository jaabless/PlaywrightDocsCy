{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES6", "DOM"],
    "types": ["cypress", "node"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["cypress/support/pages/*"],
      "@base/*": ["cypress/support/base/*"]
    }
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"]
}
